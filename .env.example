# Copy to .env and fill in real values. The real .env lives ONLY on the VPS,
# is never committed, and is listed in .gitignore.

# --- External API keys ---
# Set hard spend caps on each provider dashboard ($20 each is plenty for the demo).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Traefik / ingress ---
# Existing external Docker network Traefik is pinned to. Declared external: true in compose.
TRAEFIK_NETWORK=traefik_proxy
# Public subdomain for the Streamlit UI (the only publicly exposed service).
PUBLIC_HOSTNAME=navigator.p36server.com

# --- Basic auth for the public UI (enforced by Traefik from day one) ---
# Generate with: htpasswd -nbB <user> <password>  ->  outputs "user:hash"
# Put the user part in BASIC_AUTH_USER and ONLY the hash part (after the colon)
# in BASIC_AUTH_PASSWORD_HASH. The Traefik label rejoins them as user:hash.
# Do NOT double the `$` signs — Compose does not re-interpolate values pulled
# from .env, so single `$` is correct.
BASIC_AUTH_USER=navigator
BASIC_AUTH_PASSWORD_HASH=$2y$05$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
